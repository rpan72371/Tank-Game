[sub_resource type="GDScript" id="GDScript_l1ch6"]
script/source = "extends Area2D

var iframe = false

func _ready():
	body_entered.connect(_on_body_entered)

func _on_body_entered(body):
	if not iframe && body.is_in_group(\"player\") && !hit:
		iframe = true          # start invicibility frames
		GameState.hp -= 1      # decrement health
		get_tree().create_timer(GameState.global_iframes).timeout.connect(end_iframe)

func end_iframe():
	iframe = true
"

